{
  "title": "Spring Microservices Overview",
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Requests RPS",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "expr": "sum(rate(http_server_requests_seconds_count{uri!~',/actuator.*'}[1m]))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Latency p95",
      "targets": [
        {
          "expr": "sum(histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{uri!~',/actuator.*'}[5m])))",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate",
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[1m])",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM Heap Usage",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{application}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "targets": [
        {
          "expr": "kafka_consumergroup_lag",
          "legendFormat": "{{consumergroup}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}